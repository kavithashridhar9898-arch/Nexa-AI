PORT=5000
NODE_ENV=development

# Database Configuration
# Set to 'sqlite' for zero-config quick start, or 'mysql' for production MySQL
DB_TYPE=sqlite
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=nexus_ai_db
DB_PORT=3306

# JWT Configuration
JWT_SECRET=super-secret-jwt-key-for-nexus-ai-platform-2026
JWT_EXPIRES_IN=7d

# Nodemailer / Email Configuration
# If left blank, OTPs will be printed to the backend console for development testing
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nexus-ai.com
