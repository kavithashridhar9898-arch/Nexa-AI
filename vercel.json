{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/notifications/mark-all-read",
      "destination": "/api/notifications/mark-all-read"
    },
    {
      "source": "/api/notifications/:id/read",
      "destination": "/api/notifications/[id]"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
