# Frontend API Configuration
# In production Vercel, relative path '/api' is used out of the box.
# If hosting frontend and backend on different origins, set this value.
VITE_API_URL=/api

# Production MySQL Database Credentials
MYSQL_HOST=your-production-db-host.com
MYSQL_PORT=3306
MYSQL_DATABASE=nexus_ai_db
MYSQL_USER=your_production_user
MYSQL_PASSWORD=your_production_password

# Authentication Secrets
JWT_SECRET=generate-a-secure-random-key-phrase
JWT_EXPIRES_IN=7d

# Nodemailer / Email OTP Delivery
# Set host, port, user and pass to allow actual email sending.
EMAIL_USER=your_smtp_username
EMAIL_PASS=your_smtp_password
EMAIL_FROM=noreply@nexus-ai.com
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
